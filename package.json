{
  "name": "mochi-local-agent",
  "displayName": "Mochi",
  "description": "Local-first AI coding agent for VS Code with workspace tools, session memory, and approval-aware edits.",
  "version": "0.0.5",
  "publisher": "zee",
  "icon": "media/mochi_icon.png",
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "preview": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "setup:model": "node ./scripts/setup_model.js",
    "setup:openai": "npm run setup:model",
    "test": "node --test",
    "test:integration": "node --test test/integration/*.test.js",
    "test:report": "node ./scripts/run_test_report.js",
    "package:vsix": "npx @vscode/vsce package",
    "version:patch": "npm version patch --no-git-tag-version",
    "publish:marketplace": "npx @vscode/vsce publish",
    "release:marketplace": "npm run version:patch && npm run publish:marketplace"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SUPERpowerGT/Mochi.git"
  },
  "bugs": {
    "url": "https://github.com/SUPERpowerGT/Mochi/issues"
  },
  "homepage": "https://github.com/SUPERpowerGT/Mochi#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "dependencies": {
    "@openai/agents": "^0.1.0",
    "zod": "^3.25.40"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "agent",
    "ai",
    "chat",
    "coding",
    "developer-tools",
    "local-first",
    "openai",
    "workspace"
  ],
  "activationEvents": [
    "onCommand:localAgent.openChat",
    "onCommand:localAgent.configureModelCredentials",
    "onCommand:localAgent.sendSelection",
    "onCommand:localAgent.applyLastReply",
    "onCommand:localAgent.quickAsk",
    "onCommand:localAgent.selectWorkspaceFolder",
    "onCommand:localAgent.openMemorySnapshot",
    "onCommand:localAgent.openRawMemorySnapshot",
    "onCommand:localAgent.openMemoryControls",
    "onCommand:localAgent.togglePrivateWindowMode",
    "onCommand:localAgent.toggleSessionMemoryIsolation",
    "onCommand:localAgent.togglePersistentMemoryRead",
    "onCommand:localAgent.destroyCurrentWindowArtifacts",
    "onCommand:localAgent.clearCurrentSessionMemory",
    "onCommand:localAgent.clearCurrentSessionSummaryMemory",
    "onCommand:localAgent.clearCurrentTaskMemory",
    "onCommand:localAgent.clearCurrentWorkspaceMemory",
    "onCommand:localAgent.clearUserMemory",
    "onCommand:localAgent.clearCurrentTraceMemory",
    "onCommand:localAgent.clearAllMemory",
    "onView:localAgent.chatView"
  ],
  "main": "./src/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "localAgentPanel",
          "title": "Mochi",
          "icon": "media/mochi_logo.svg"
        }
      ]
    },
    "views": {
      "localAgentPanel": [
        {
          "type": "webview",
          "id": "localAgent.chatView",
          "name": "Mochi"
        }
      ]
    },
    "commands": [
      {
        "command": "localAgent.openChat",
        "title": "Local Agent: Open Chat"
      },
      {
        "command": "localAgent.configureModelCredentials",
        "title": "Mochi: Configure Model Credentials"
      },
      {
        "command": "localAgent.sendSelection",
        "title": "Local Agent: Ask About Selection"
      },
      {
        "command": "localAgent.applyLastReply",
        "title": "Local Agent: Replace Selection With Last Reply"
      },
      {
        "command": "localAgent.quickAsk",
        "title": "Local Agent: Quick Ask"
      },
      {
        "command": "localAgent.selectWorkspaceFolder",
        "title": "Local Agent: Select Workspace Folder"
      },
      {
        "command": "localAgent.openMemorySnapshot",
        "title": "Local Agent: Open Memory Snapshot"
      },
      {
        "command": "localAgent.openRawMemorySnapshot",
        "title": "Local Agent: Open Raw Memory Snapshot"
      },
      {
        "command": "localAgent.openMemoryControls",
        "title": "Mochi: Open Memory Controls"
      },
      {
        "command": "localAgent.togglePrivateWindowMode",
        "title": "Mochi: Toggle Current Window Private Mode"
      },
      {
        "command": "localAgent.toggleSessionMemoryIsolation",
        "title": "Mochi: Toggle Current Window Memory Isolation"
      },
      {
        "command": "localAgent.togglePersistentMemoryRead",
        "title": "Mochi: Toggle Current Window Persistent Memory Reads"
      },
      {
        "command": "localAgent.destroyCurrentWindowArtifacts",
        "title": "Mochi: Delete Current Window Artifacts"
      },
      {
        "command": "localAgent.clearCurrentSessionMemory",
        "title": "Mochi: Clear Current Window Memory"
      },
      {
        "command": "localAgent.clearCurrentSessionSummaryMemory",
        "title": "Mochi: Clear Current Session Summary Memory"
      },
      {
        "command": "localAgent.clearCurrentTaskMemory",
        "title": "Mochi: Clear Current Window Working State"
      },
      {
        "command": "localAgent.clearCurrentWorkspaceMemory",
        "title": "Mochi: Clear Current Workspace Memory"
      },
      {
        "command": "localAgent.clearUserMemory",
        "title": "Mochi: Clear User Memory"
      },
      {
        "command": "localAgent.clearCurrentTraceMemory",
        "title": "Mochi: Clear Current Trace Memory"
      },
      {
        "command": "localAgent.clearAllMemory",
        "title": "Mochi: Clear All Local Memory"
      }
    ],
    "configuration": {
      "title": "Mochi",
      "properties": {
        "mochi.modelProvider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "gemini",
            "openai-compatible"
          ],
          "description": "Model provider Mochi should use."
        },
        "mochi.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible API base URL used by Mochi."
        },
        "mochi.model": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "Default model Mochi should use."
        },
        "mochi.apiFormat": {
          "type": "string",
          "default": "chat_completions",
          "enum": [
            "chat_completions",
            "responses"
          ],
          "description": "OpenAI API format Mochi should use."
        }
      }
    }
  }
}
