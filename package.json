{
  "name": "local-agent-chat",
  "displayName": "Mochi",
  "description": "A local VS Code chat agent with session memory, workspace tools, and cautious file editing.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SUPERpowerGT/Mochi.git"
  },
  "type": "commonjs",
  "scripts": {
    "setup:openai": "node ./scripts/setup_openai.js"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "dependencies": {
    "@openai/agents": "^0.1.0",
    "zod": "^3.25.40"
  },
  "scripts": {
    "test": "node --test --test-reporter=spec \"test/unit/*.test.js\"",
    "test:watch": "node --test --watch --test-reporter=spec \"test/unit/*.test.js\"",
    "test:file": "node --test --test-reporter=spec",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=spec \"test/unit/*.test.js\""
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:localAgent.openChat",
    "onCommand:localAgent.sendSelection",
    "onCommand:localAgent.applyLastReply",
    "onCommand:localAgent.quickAsk",
    "onCommand:localAgent.signIn",
    "onCommand:localAgent.register",
    "onCommand:localAgent.signOut",
    "onCommand:localAgent.switchDeviceProfile",
    "onCommand:localAgent.switchUserProfile",
    "onCommand:localAgent.restoreCheckpoint",
    "onCommand:localAgent.analyzeLatestCommit",
    "onCommand:localAgent.selectWorkspaceFolder",
    "onCommand:localAgent.openMemorySnapshot",
    "onCommand:localAgent.openRawMemorySnapshot",
    "onView:localAgent.chatView"
  ],
  "main": "./src/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "localAgentPanel",
          "title": "Mochi",
          "icon": "media/mochi_logo.svg"
        }
      ]
    },
    "views": {
      "localAgentPanel": [
        {
          "type": "webview",
          "id": "localAgent.chatView",
          "name": "Mochi"
        }
      ]
    },
    "commands": [
      {
        "command": "localAgent.openChat",
        "title": "Local Agent: Open Chat"
      },
      {
        "command": "localAgent.sendSelection",
        "title": "Local Agent: Ask About Selection"
      },
      {
        "command": "localAgent.applyLastReply",
        "title": "Local Agent: Replace Selection With Last Reply"
      },
      {
        "command": "localAgent.quickAsk",
        "title": "Local Agent: Quick Ask"
      },
      {
        "command": "localAgent.signIn",
        "title": "Local Agent: Sign In"
      },
      {
        "command": "localAgent.register",
        "title": "Local Agent: Register"
      },
      {
        "command": "localAgent.signOut",
        "title": "Local Agent: Sign Out"
      },
      {
        "command": "localAgent.switchDeviceProfile",
        "title": "Local Agent: Switch Device Profile"
      },
      {
        "command": "localAgent.switchUserProfile",
        "title": "Local Agent: Switch User Profile"
      },
      {
        "command": "localAgent.restoreCheckpoint",
        "title": "Local Agent: Restore Checkpoint"
      },
      {
        "command": "localAgent.analyzeLatestCommit",
        "title": "Local Agent: Analyze Latest Commit"
      },
      {
        "command": "localAgent.selectWorkspaceFolder",
        "title": "Local Agent: Select Workspace Folder"
      },
      {
        "command": "localAgent.openMemorySnapshot",
        "title": "Local Agent: Open Memory Snapshot"
      },
      {
        "command": "localAgent.openRawMemorySnapshot",
        "title": "Local Agent: Open Raw Memory Snapshot"
      }
    ]
  }
}
